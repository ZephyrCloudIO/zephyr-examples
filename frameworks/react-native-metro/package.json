{
  "name": "zephyr-metro-example",
  "license": "MIT",
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "prepare": "pnpm build",
    "build": "turbo build",
    "dev:example": "turbo dev --filter=example-host --filter=MFTextEditor --filter=MFNotesList --ui=tui",
    "build:ios": "turbo build:ios --filter=MFTextEditor --filter=MFNotesList",
    "build:ios:zephyr": "turbo build:ios:zephyr --filter=MFTextEditor --filter=MFNotesList",
    "ios:release:zephyr": "turbo ios:release:zephyr --filter=example-host",
    "ios:release": "turbo ios:release --filter=example-host",
    "serve:ios": "turbo serve:ios --filter=MFTextEditor --filter=MFNotesList --ui=tui",
    "release:ios": "cd apps/example-host && pnpm ios:release",
    "ios": "cd apps/example-host && pnpm ios",
    "release:ios:zephyr": "cd apps/example-host && pnpm ios:release:zephyr",
    "pods": "pnpm --filter example-host run pods",
    "lint": "biome check --write",
    "lint:ci": "biome check",
    "typecheck": "turbo typecheck",
    "clean:ios": "rm -rf apps/example-host/.rnef/cache/*"
  },
  "devDependencies": {
    "@biomejs/biome": "1.9.4",
    "turbo": "2.5.4"
  },
  "pnpm": {
    "overrides": {
      "brace-expansion": ">=1.1.13",
      "js-yaml": ">=4.1.1",
      "fast-xml-parser": "5.5.7"
    }
  }
}
