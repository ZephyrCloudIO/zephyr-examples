{
  "name": "vite-ember",
  "version": "0.0.0",
  "private": true,
  "description": "Small description for vite-ember goes here",
  "repository": "",
  "license": "MIT",
  "author": "",
  "directories": {
    "doc": "doc",
    "test": "tests"
  },
  "scripts": {
    "build": "vite build",
    "format": "prettier . --cache --write",
    "lint": "concurrently \"npm:lint:*(!fix)\" --names \"lint:\" --prefixColors auto",
    "lint:css": "stylelint \"**/*.css\"",
    "lint:css:fix": "concurrently \"npm:lint:css -- --fix\"",
    "lint:fix": "concurrently \"npm:lint:*:fix\" --names \"fix:\" --prefixColors auto && npm run format",
    "lint:format": "prettier . --cache --check",
    "lint:hbs": "ember-template-lint .",
    "lint:hbs:fix": "ember-template-lint . --fix",
    "lint:js": "eslint . --cache",
    "lint:js:fix": "eslint . --fix",
    "start": "vite",
    "test": "concurrently \"npm:lint\" \"npm:test:*\" --names \"lint,test:\" --prefixColors auto",
    "test:ember": "vite build --mode test && testem ci"
  },
  "exports": {
    "./tests/*": "./tests/*",
    "./*": "./app/*"
  },
  "devDependencies": {
    "@babel/core": "7.29.0",
    "@babel/eslint-parser": "7.28.6",
    "@babel/plugin-transform-runtime": "7.29.0",
    "@babel/runtime": "7.28.4",
    "@ember/optional-features": "2.3.0",
    "@ember/string": "4.0.1",
    "@ember/test-helpers": "5.4.1",
    "@ember/test-waiters": "4.1.1",
    "@embroider/compat": "4.1.16",
    "@embroider/config-meta-loader": "1.0.0",
    "@embroider/core": "4.4.7",
    "@embroider/macros": "1.20.2",
    "@embroider/router": "3.0.6",
    "@embroider/vite": "1.7.1",
    "@eslint/js": "9.39.2",
    "@glimmer/component": "^2.0.0",
    "@rollup/plugin-babel": "6.1.0",
    "@warp-drive/ember": "5.8.1",
    "babel-plugin-ember-template-compilation": "3.1.0",
    "concurrently": "9.2.1",
    "decorator-transforms": "2.3.1",
    "ember-auto-import": "2.13.0",
    "ember-cli": "6.8.1",
    "ember-cli-babel": "8.3.1",
    "ember-cli-deprecation-workflow": "3.4.0",
    "ember-data": "5.8.1",
    "ember-load-initializers": "3.0.1",
    "ember-modifier": "4.3.0",
    "ember-page-title": "9.0.3",
    "ember-qunit": "9.0.4",
    "ember-resolver": "13.2.0",
    "ember-source": "6.8.3",
    "ember-template-lint": "7.9.3",
    "ember-welcome-page": "8.0.5",
    "eslint": "9.39.2",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-ember": "12.7.5",
    "eslint-plugin-n": "17.24.0",
    "eslint-plugin-qunit": "8.2.6",
    "globals": "16.5.0",
    "prettier": "3.8.1",
    "prettier-plugin-ember-template-tag": "2.1.3",
    "qunit": "2.25.0",
    "qunit-dom": "3.5.0",
    "stylelint": "16.26.1",
    "stylelint-config-standard": "39.0.1",
    "testem": "3.19.0",
    "tracked-built-ins": "4.1.2",
    "vite": "7.3.1",
    "vite-plugin-zephyr": "latest"
  },
  "engines": {
    "node": ">= 18"
  },
  "ember": {
    "edition": "octane"
  }
}
