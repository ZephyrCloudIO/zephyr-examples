{
  "name": "mobile-core",
  "version": "0.0.1",
  "description": "Core app utilities including auth, api, data and UI",
  "main": "./src/index.ts",
  "module": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./lib/typescript/commonjs/src/index.d.ts",
      "default": "./src/index.ts"
    }
  },
  "files": [
    "src"
  ],
  "scripts": {
    "align-deps": "rnx-align-deps --presets ./node_modules/mobile-sdk/preset --requirements mobile-sdk@0.0.1 --write",
    "check-deps": "rnx-align-deps --presets ./node_modules/mobile-sdk/preset --requirements mobile-sdk@0.0.1",
    "lint": "eslint . --ext .js,.ts,.tsx",
    "typecheck": "tsc",
    "test": "jest --passWithNoTests"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.64.2",
    "i18next": "24.0.2",
    "react-hook-form": "^7.54.2",
    "react-i18next": "15.1.2",
    "react-native-localize": "3.3.0",
    "react-native-safe-area-context": "5.4.0",
    "react-native-screen-corner-radius": "0.2.2",
    "react-native-vector-icons": "10.2.0",
    "zustand": "^5.0.3"
  },
  "peerDependencies": {
    "react": "19.0.0",
    "react-native": "0.79.4",
    "react-native-config": "1.5.3",
    "react-native-mmkv": "3.1.0",
    "react-native-paper": "5.12.5"
  },
  "devDependencies": {
    "@callstack/eslint-config": "^15.0.0",
    "@rnx-kit/align-deps": "^2.5.5",
    "mobile-sdk": "0.0.1",
    "@react-native/eslint-config": "0.79.4",
    "@react-native/typescript-config": "0.79.4",
    "@swc/helpers": "0.5.15",
    "@types/jest": "^29.5.14",
    "@types/node": "^24.0.0",
    "@types/react": "^18.2.6",
    "@types/react-native-vector-icons": "^6.4.12",
    "eslint": "^8.57.0",
    "eslint-plugin-barrel-files": "^2.1.0",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "jest": "^29.6.3",
    "react": "19.0.0",
    "react-native": "0.79.4",
    "react-native-config": "1.5.3",
    "react-native-mmkv": "3.1.0",
    "react-native-paper": "5.12.5",
    "typescript": "^5.6.3"
  },
  "jest": {
    "preset": "react-native",
    "modulePathIgnorePatterns": [
      "<rootDir>/lib/"
    ]
  }
}
